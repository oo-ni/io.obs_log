---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths() {
  const slug = (t: string) => t.toLowerCase().replace(/\s+/g, "-");
  const posts = await getCollection("posts");
  const names = [...new Set(posts.flatMap((p) => p.data.tags))];
  return names.map((name) => ({
    params: { tag: slug(name) },
    props: {
      name,
      posts: posts
        .filter((p) => p.data.tags.includes(name))
        .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)),
    },
  }));
}

const { name, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<Base title={`#${name}`}>
  <div class="page-head">
    <h1>#{name}</h1>
  </div>
  <div class="card-grid">
    {posts.map((p, i) => <PostCard post={p} index={i} />)}
  </div>
  <p style="margin-top:2rem"><a class="back-link" href={`${base}tags`}>← All tags</a></p>
</Base>
