---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import Sidebar from "../components/Sidebar.astro";
import Socials from "../components/Socials.astro";
interface Props { title: string; description?: string; sidebar?: boolean; }
const { title, description = "Notes on backend development", sidebar = true } = Astro.props;
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === base ? path === base : path.startsWith(href);
const nav = [
  { href: `${base}posts`, label: "Posts" },
  { href: `${base}tags`, label: "Tags" },
  { href: `${base}archives`, label: "Archives" },
];
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <Font cssVariable="--font-google-sans-code" preload />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" rel="stylesheet" />
    <ClientRouter />
    {/* 테마 적용: 첫 페인트 전 + View Transitions 스왑마다 재적용(리셋/깜빡임 방지) */}
    <script is:inline>
      (function () {
        const apply = () => {
          const t = localStorage.getItem("theme") ||
            (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.dataset.theme = t;
        };
        apply();
        document.addEventListener("astro:after-swap", apply);
      })();
    </script>
  </head>
  <body>
    <header class="site-header" data-pagefind-ignore>
      <div class="header-inner">
        <a class="brand" href={base}>dev_log</a>
        <button class="menu-btn" id="menuBtn" aria-label="Menu" aria-expanded="false">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
        </button>
        <nav class="site-nav" id="siteNav">
          <ul class="nav-links">
            {nav.map((n) => (
              <li><a href={n.href} class={isActive(n.href) ? "active-nav" : ""}>{n.label}</a></li>
            ))}
          </ul>
          <div class="nav-actions">
            <a class="icon-btn" href={`${base}search`} aria-label="Search" title="Search">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </a>
            <button class="icon-btn theme-toggle" id="themeToggle" aria-label="Toggle theme" aria-live="polite">
              <svg class="icon moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              <svg class="icon sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            </button>
          </div>
        </nav>
      </div>
    </header>
    <main>
      {sidebar ? (
        <div class="layout">
          <Sidebar />
          <div class="content"><slot /></div>
        </div>
      ) : (
        <div class="prose-wrap"><slot /></div>
      )}
    </main>
    <footer class="site-footer" data-pagefind-ignore>
      <Socials />
      <p class="footer-copy">© 2026. oo-ni All rights reserved.</p>
    </footer>

    <script>
      // document는 View Transitions 스왑에도 유지되므로 위임 핸들러 1회만 등록.
      const root = document.documentElement;
      const reduceMotion = () => matchMedia("(prefers-reduced-motion: reduce)").matches;

      function toggleTheme(x: number, y: number) {
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        const apply = () => {
          root.dataset.theme = next;
          localStorage.setItem("theme", next);
        };
        // @ts-ignore - startViewTransition 미지원 브라우저 폴백
        if (!document.startViewTransition || reduceMotion()) { apply(); return; }
        const endR = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
        root.classList.add("theme-vt");
        // @ts-ignore
        const vt = document.startViewTransition(apply);
        vt.ready.then(() => {
          root.animate(
            { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${endR}px at ${x}px ${y}px)`] },
            { duration: 450, easing: "ease-in-out", pseudoElement: "::view-transition-new(root)" }
          );
        });
        vt.finished.finally(() => root.classList.remove("theme-vt"));
      }

      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const themeBtn = target.closest?.("#themeToggle");
        if (themeBtn) {
          const ev = e as MouseEvent;
          const r = (themeBtn as HTMLElement).getBoundingClientRect();
          const x = ev.clientX || r.left + r.width / 2;
          const y = ev.clientY || r.top + r.height / 2;
          toggleTheme(x, y);
          return;
        }
        const menuBtn = target.closest?.("#menuBtn");
        if (menuBtn) {
          const nav = document.getElementById("siteNav");
          const open = nav?.classList.toggle("open");
          menuBtn.setAttribute("aria-expanded", open ? "true" : "false");
        }
      });
    </script>
  </body>
</html>
