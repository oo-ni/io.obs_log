---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
interface Props { title: string; description?: string; sidebar?: boolean; }
const { title, description = "백엔드 개발 학습 기록", sidebar = true } = Astro.props;
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === base ? path === base : path.startsWith(href);
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" rel="stylesheet" />
    {/* 다크모드 깜빡임 방지: 페인트 전에 테마 적용 */}
    <script is:inline>
      (function () {
        const t = localStorage.getItem("theme") ||
          (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={base}>oo-ni.log</a>
        <nav class="site-nav">
          <a href={base} class={isActive(base) ? "active" : ""}>Posts</a>
          <a href={`${base}tags`} class={isActive(`${base}tags`) ? "active" : ""}>Tags</a>
          <a href={`${base}about`} class={isActive(`${base}about`) ? "active" : ""}>About</a>
          <button class="theme-toggle" id="themeToggle" aria-label="테마 전환">◐</button>
        </nav>
      </div>
    </header>
    <main>
      {sidebar ? (
        <div class="layout">
          <Sidebar />
          <div class="content"><slot /></div>
        </div>
      ) : (
        <div class="prose-wrap"><slot /></div>
      )}
    </main>
    <footer class="site-footer">© 2026 oo-ni · Built with Astro</footer>

    <script is:inline>
      document.getElementById("themeToggle")?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
      });
    </script>
  </body>
</html>
