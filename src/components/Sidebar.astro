---
import { getCollection } from "astro:content";
import { buildTree } from "../lib/categories";
import CategoryTree from "./CategoryTree.astro";
import Socials from "./Socials.astro";

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

const posts = await getCollection("posts");
const tree = buildTree(posts);

const prefix = `${base}categories/`;
const currentSlug = path.startsWith(prefix)
  ? decodeURIComponent(path.slice(prefix.length).replace(/\/$/, ""))
  : "";
const postsPath = `${base}posts`;
const isAll = path === postsPath || path === `${postsPath}/`;
---
<aside class="sidebar" data-pagefind-ignore>
  <section class="side-block">
    <h3 class="side-title">📂 Categories</h3>
    <ul class="cat-list" data-depth="0">
      <li>
        <a href={postsPath} class={isAll ? "active" : ""}>
          All <span class="count">{posts.length}</span>
        </a>
      </li>
    </ul>
    <CategoryTree nodes={tree} currentSlug={currentSlug} base={base} />
  </section>

  <section class="side-block profile">
    <!-- <div class="avatar">O</div> -->
    <div class="pname">oo-ni</div>
    <div class="ptitle">Software Engineer</div>
    <p class="pbio">Within what you can control, the depth of your desire decides everything.</p>
    <Socials />
  </section>
</aside>
