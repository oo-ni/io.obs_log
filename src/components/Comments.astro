---
interface Props { title?: string }
const { title = "" } = Astro.props;

const host = "https://cusdis.com";
const appId = "d74e0dc5-60ed-4ca5-ae02-7b5a5178c82c";
const pageId = Astro.url.pathname;     // 글마다 고유 (경로 기준)
const pageUrl = Astro.url.href;
---
<section class="comments" data-pagefind-ignore>
  <div
    id="cusdis_thread"
    data-host={host}
    data-app-id={appId}
    data-page-id={pageId}
    data-page-url={pageUrl}
    data-page-title={title}
  >
  </div>
</section>

<script>
  const curTheme = () =>
    document.documentElement.dataset.theme === "dark" ? "dark" : "light";

  function loadCusdis() {
    const el = document.getElementById("cusdis_thread");
    if (!el) return; // 댓글 영역 없는 페이지

    if ((el.dataset.appId || "").startsWith("REPLACE")) {
      el.innerHTML =
        '<p class="comments-note">댓글이 아직 설정되지 않았습니다. <code>src/components/Comments.astro</code>에 Cusdis App ID를 입력하세요.</p>';
      return;
    }

    el.setAttribute("data-theme", curTheme()); // 초기 테마
    const render = () => (window as any).CUSDIS?.initial?.();

    if ((window as any).CUSDIS) {
      render(); // 스크립트는 이미 로드됨 (뷰 트랜지션 재진입)
      return;
    }
    const s = document.createElement("script");
    s.src = "https://cusdis.com/js/cusdis.es.js";
    s.async = true;
    s.onload = render;
    document.body.appendChild(s);
  }

  document.addEventListener("astro:page-load", loadCusdis);

  // 테마 토글 시 Cusdis iframe 에도 반영
  const syncTheme = () => {
    const el = document.getElementById("cusdis_thread");
    if (!el) return;
    el.setAttribute("data-theme", curTheme());
    const iframe = document.querySelector<HTMLIFrameElement>("#cusdis_thread iframe");
    iframe?.contentWindow?.postMessage(
      { from: "cusdis", event: "setTheme", data: curTheme() },
      "*"
    );
  };
  new MutationObserver(syncTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });
</script>
